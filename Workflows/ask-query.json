me about IPL news\\\"}\\n{\\\"route\\\":\\\"research_chatbot\\\",\\\"query\\\":\\\"What are ecommerce return policy best practices\\\"}\\n{\\\"route\\\":\\\"hybrid\\\",\\\"query\\\":\\\"Compare AcmeAI's refund policy with ecommerce return trends\\\"}\\n{\\\"route\\\":\\\"hybrid\\\",\\\"query\\\":\\\"Is our pricing competitive with current market options\\\"}\\n\\nReturn ONLY valid JSON. No markdown. Format: {\\\"route\\\":\\\"knowledge_base\\\",\\\"query\\\":\\\"cleaned user query\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $('Webhook').item.json.body.question }}\"\n    }\n  ],\n  \"temperature\": 0\n}",
        "options": {}

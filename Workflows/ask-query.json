        "jsCode": "// Get the raw response from Groq\nlet raw = $json.choices[0].message.content || \"\";\n\n// Remove markdown code fences if present\nraw = raw\n  .replace(/```json\\s*/gi, \"\")\n  .replace(/```\\s*/g, \"\")\n  .trim();\n\n// Parse the JSON\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch (err) {\n  throw new Error(\n    `Failed to parse router output.\\n\\nRaw response:\\n${raw}\\n\\nError: ${err.message}`\n  );\n}\n\n// Return clean output\nreturn [\n  {\n    json: {\n      route: parsed.route,\n      query: parsed.query\n    }\n  }\n];"
      },
